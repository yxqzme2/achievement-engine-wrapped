# ---------------------------------------------------------------
# achievement-engine — environment variables
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------------

# URL of the abs-stats companion service (default: http://abs-stats:3000)
ABSSTATS_BASE_URL=http://abs-stats:3000

# How often to poll abs-stats for new data (seconds)
POLL_SECONDS=300

# Path to the SQLite state database inside the container
STATE_DB_PATH=/data/state.db

# Timezone (for date display)
TZ=America/New_York

# Unix timestamp (seconds) when the progression economy starts
# Books/XP/loot earned only after this date count toward leveling
XP_START_TIMESTAMP=1767225600

# ---------------------------------------------------------------
# Completion verification
# ---------------------------------------------------------------
STRICT_VERIFICATION=false
VERIFY_LISTEN_THRESHOLD=0.80
REQUIRE_DURATION_FOR_CREDIT=true
REQUIRE_2026_SESSION_FOR_CREDIT=true

# ---------------------------------------------------------------
# Users
# ---------------------------------------------------------------
# Optional: comma-separated ABS usernames to include. Leave empty for all users.
ALLOWED_USERS=

# Optional: display name aliases. Format: absusername:Display Name,...
USER_ALIASES=

# Optional: custom avatar images per user. Format: absusername:/icons/avatar.png,...
USER_ICONS=

# ---------------------------------------------------------------
# Wrapped year-end experience
# ---------------------------------------------------------------
WRAPPED_YEAR=2026
WRAPPED_BOSS_HP=250000

# ---------------------------------------------------------------
# Achievement backfill (one-time startup)
# ---------------------------------------------------------------
RUN_ACHIEVEMENT_BACKFILL=false
BACKFILL_ONCE_KEY=ach_backfill_v1

# ---------------------------------------------------------------
# SMTP (optional — for email notifications)
# ---------------------------------------------------------------
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=noreply@yourdomain.com
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_FROM=The System noreply@yourdomain.com
SMTP_TO_OVERRIDE=
SEND_TEST_EMAIL=false
SMTP_DEBUG=0

# ---------------------------------------------------------------
# abs-stats companion service (set in docker-compose.override.yml)
# ---------------------------------------------------------------
# ABS_URL=http://your-audiobookshelf:13378
# ABS_TOKEN=your-abs-api-token
# ABS_TOKENS=absuser1:token1,absuser2:token2
# ALLOWED_USERNAMES=*
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
