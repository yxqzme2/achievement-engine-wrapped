<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Listener's Sanctum</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Lato:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #121212;
            --window-bg: #e8dbc3;
            --border-color: #4a3b2a;
            --gold-accent: #b89548;
            --ink: #2b2018;
            --ink-muted: #665243;
            --tab-bg: #3d2f24;
            --tab-text: #a89582;
            --tab-hover: #4f3d2f;
            --font-title: "Cinzel", serif;
            --font-body: "Lato", sans-serif;

            /* Rarity Colors */
            --r-common: #a0a0a0;
            --r-uncommon: #3bd26f;
            --r-rare: #0070dd;
            --r-epic: #a335ee;
            --r-legendary: #ff8000;
        }

        body {
            margin: 0;
            background-color: var(--bg-dark);
            background-image: radial-gradient(circle at center, #1f1f1f 0%, #050505 100%);
            color: var(--tab-text);
            font-family: var(--font-body);
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* --- HEADER --- */
        .sanctum-header {
            text-align: center;
            margin-bottom: 50px;
            animation: fadeInDown 1s ease-out;
        }

        .sanctum-title {
            font-family: var(--font-title);
            font-size: 3.5rem;
            color: var(--gold-accent);
            margin: 0;
            text-shadow: 0 4px 20px rgba(184, 149, 72, 0.3);
            letter-spacing: 2px;
        }

        .sanctum-subtitle {
            font-size: 1.1rem;
            color: var(--tab-text);
            opacity: 0.8;
            margin-top: 10px;
            font-style: italic;
        }

        /* --- PORTAL GRID --- */
        .portal-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            max-width: 1100px;
            width: 90%;
            padding: 20px;
        }

        /* --- CARDS --- */
        .portal-card {
            background: var(--tab-bg);
            background-image: linear-gradient(to bottom, rgba(255,255,255,0.05), rgba(0,0,0,0.3));
            border: 2px solid var(--border-color);
            border-radius: 8px;
            padding: 30px 20px;
            text-align: center;
            text-decoration: none;
            color: var(--tab-text);
            transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .portal-card::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 50%; height: 100%;
            background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(184, 149, 72, 0.1) 50%, rgba(255,255,255,0) 100%);
            transform: skewX(-25deg);
            transition: all 0.7s ease;
        }

        .portal-card:hover {
            transform: translateY(-8px);
            border-color: var(--gold-accent);
            box-shadow: 0 15px 40px rgba(0,0,0,0.8), 0 0 15px rgba(184, 149, 72, 0.3);
            color: #dccaa5;
        }

        .portal-card:hover::before {
            left: 200%;
        }

        .portal-icon {
            font-size: 3rem;
            margin-bottom: 15px;
            filter: drop-shadow(0 2px 5px rgba(0,0,0,0.5));
            transition: transform 0.3s;
        }

        .portal-card:hover .portal-icon {
            transform: scale(1.1);
        }

        .portal-name {
            font-family: var(--font-title);
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--gold-accent);
            margin-bottom: 10px;
        }

        .portal-desc {
            font-size: 0.9rem;
            line-height: 1.4;
            opacity: 0.8;
        }

        /* --- SPECIFIC CARD STYLING --- */
        .card-admin {
            border-style: dashed;
            background-image: linear-gradient(to bottom, rgba(255, 128, 0, 0.05), rgba(0,0,0,0.4));
        }

        /* ===== MOBILE RESPONSIVE ===== */
        @media (max-width: 900px) {
            .portal-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .sanctum-title { font-size: 2.8rem; }
        }

        @media (max-width: 600px) {
            .portal-grid {
                grid-template-columns: 1fr;
            }
            .sanctum-title { font-size: 2.2rem; }
        }

        /* Animations */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ===== NAV BAR ===== */
        .nav-bar { display:flex; justify-content:space-between; align-items:center; padding:12px 40px; background:var(--tab-bg); border-bottom:3px solid #2a2118; background-image:linear-gradient(to bottom,rgba(255,255,255,.05),rgba(0,0,0,.2)); flex-wrap:wrap; gap:6px; width:100%; box-sizing:border-box; }
        .nav-bar a { color:var(--tab-text); text-decoration:none; font-family:var(--font-title); font-size:.95rem; padding:6px 16px; border-radius:4px; transition:all .2s; }
        .nav-bar a:hover { background:#4f3d2f; color:#dccaa5; }
        .nav-bar a.active { color:var(--gold-accent); font-weight:700; }
        .nav-bar a.nav-title { color:var(--gold-accent); font-size:1.1rem; font-weight:700; letter-spacing:1px; padding:0; background:none; }
        .nav-bar a.nav-title:hover { background:none; color:#dccaa5; }
        @media(max-width:768px){ .nav-bar{ padding:10px 15px; } .nav-bar a{ font-size:.8rem; padding:4px 10px; } .nav-bar a.nav-title{ font-size:.9rem; } }
    </style>
</head>
<body>

    <nav class="nav-bar">
        <a href="/" class="nav-title active">The Listener's Sanctum</a>
        <div>
            <a href="/journal">Journal</a>
            <a href="/champions">Leaderboard</a>
            <a href="/roster">Roster</a>
            <a href="/timeline">Timeline</a>
            <a href="/archives">Stats</a>
            <a href="/playlist">Playlist</a>
            <a href="/tier">Tier List</a>
            <a href="/loot">Loot</a>
        </div>
    </nav>

    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;flex:1;width:100%;padding:40px 20px;box-sizing:border-box;">
    <div class="sanctum-header">
        <h1 class="sanctum-title">The Listener's Sanctum</h1>
        <div class="sanctum-subtitle">Choose your path to progression</div>
    </div>

    <div class="portal-grid">
        
        <a href="/journal" class="portal-card">
            <div class="portal-icon">📖</div>
            <div class="portal-name">The Journal</div>
            <div class="portal-desc">View your personal achievements, milestones, and earned progression points.</div>
        </a>

        <a href="/champions" class="portal-card">
            <div class="portal-icon">👑</div>
            <div class="portal-name">Hall of Champions</div>
            <div class="portal-desc">See how you stack up against the realm. View global rankings and recent deeds.</div>
        </a>

        <a href="/roster" class="portal-card">
            <div class="portal-icon">⚔️</div>
            <div class="portal-name">The Roster</div>
            <div class="portal-desc">View the full list of adventurers, their combat power, and equipped gear.</div>
        </a>

        <a href="/timeline" class="portal-card">
            <div class="portal-icon">📜</div>
            <div class="portal-name">Chronicle of Deeds</div>
            <div class="portal-desc">An unbroken timeline of all achievements unlocked across the server.</div>
        </a>

        <a href="/playlist" class="portal-card">
            <div class="portal-icon">🎧</div>
            <div class="portal-name">The Archives</div>
            <div class="portal-desc">Browse your active playlists and track which epics you have finished.</div>
        </a>

        <a href="/tier" class="portal-card">
            <div class="portal-icon">📊</div>
            <div class="portal-name">Tier List Maker</div>
            <div class="portal-desc">Drag and drop your library covers to rank the best (and worst) series.</div>
        </a>

        <a href="/archives" class="portal-card">
            <div class="portal-icon">📡</div>
            <div class="portal-name">The Observatory</div>
            <div class="portal-desc">Live listening stats, session history, and activity data across the server.</div>
        </a>

        <a href="/loot" class="portal-card">
            <div class="portal-icon">💰</div>
            <div class="portal-name">The Vault</div>
            <div class="portal-desc">Browse the full Loot Compendium and view all potential artifacts in the realm.</div>
        </a>

        <a href="#" class="portal-card" onclick="openQuestBoard(event)">
            <div class="portal-icon">📜</div>
            <div class="portal-name">The Quest Board</div>
            <div class="portal-desc">View all active bounties and campaigns currently hard-coded into the System.</div>
        </a>

    </div>
    </div>

    <!-- Quest Board Modal -->
    <div id="quest-modal" class="qmodal-overlay">
        <div class="qmodal-container">
            <div class="qmodal-header">
                <h2>SYSTEM QUEST BOARD</h2>
                <button class="qclose-btn" onclick="closeQuestBoard()">&times;</button>
            </div>
            <div class="qmodal-content">
                <div id="quest-list" class="quest-board-grid">
                    <!-- Quests populated by JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Quest Tooltip -->
    <div id="quest-tooltip" class="q-tooltip"></div>

    <!-- Cover Fan Overlay (New) -->
    <div id="cover-overlay" class="cover-overlay" onclick="closeCovers()">
        <div id="cover-fan" class="cover-fan"></div>
        <div id="cover-title" class="cover-title-display"></div>
    </div>

    <style>
        /* --- Quest Board Modal Styling --- */
        .qmodal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(10px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .qmodal-container {
            background: #050a0f;
            border: 2px solid var(--gold-accent);
            width: 100%;
            max-width: 1000px;
            height: 85vh;
            display: flex;
            flex-direction: column;
            box-shadow: 0 0 50px rgba(184, 149, 72, 0.2);
            border-radius: 4px;
        }

        .qmodal-header {
            padding: 20px;
            border-bottom: 1px solid rgba(184, 149, 72, 0.3);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .qmodal-header h2 {
            margin: 0;
            font-family: var(--font-title);
            color: var(--gold-accent);
            letter-spacing: 3px;
        }

        .qclose-btn {
            background: none;
            border: none;
            color: #fff;
            font-size: 2rem;
            cursor: pointer;
        }

        .qmodal-content {
            flex: 1;
            overflow-y: auto;
            padding: 30px;
        }

        .quest-board-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }

        .quest-post {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid #333;
            padding: 20px;
            position: relative;
            transition: all 0.3s;
            border-left: 4px solid var(--gold-accent);
            cursor: pointer;
        }

        .quest-post:hover {
            background: rgba(184, 149, 72, 0.05);
            border-color: var(--gold-accent);
            transform: translateY(-3px);
        }

        .q-type {
            font-size: 0.7rem;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: block;
            margin-bottom: 5px;
        }

        .q-name {
            font-family: var(--font-title);
            font-size: 1.2rem;
            color: #fff;
            margin-bottom: 10px;
            display: block;
        }

        .q-target {
            color: var(--gold-accent);
            font-weight: bold;
            font-size: 0.9rem;
            margin-bottom: 10px;
            display: block;
        }

        .q-desc {
            font-size: 0.9rem;
            line-height: 1.5;
            color: #ccc;
            margin-bottom: 15px;
            font-style: italic;
        }

        .q-rewards {
            border-top: 1px solid #222;
            padding-top: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .q-xp {
            color: #00e5ff;
            font-weight: bold;
            font-size: 0.85rem;
        }

        .q-loot {
            color: #ffaa00;
            font-size: 0.75rem;
            text-transform: uppercase;
            font-weight: 900;
        }

        /* --- Cover Fan Overlay --- */
        .cover-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.9);
            z-index: 2000;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(10px);
        }

        .cover-fan {
            position: relative;
            width: 360px;
            height: 360px;
            perspective: 1200px;
        }

        .fan-item {
            position: absolute;
            width: 360px;
            height: 360px;
            border: 2px solid var(--gold-accent);
            border-radius: 12px;
            box-shadow: 0 15px 45px rgba(0,0,0,0.9);
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease, border-color 0.4s ease;
            transform-origin: center bottom;
            background: #111;
            overflow: hidden;
            cursor: pointer;
            will-change: transform;
        }

        /* Fixed the 'glitch' by ensuring the hover transform doesn't jump the card too far from the cursor */
        .fan-item:hover {
            z-index: 500 !important;
            transform: translateY(-60px) scale(1.25) !important;
            border-color: #fff;
            box-shadow: 0 30px 80px rgba(0,0,0,1), 0 0 30px rgba(255,255,255,0.4);
        }

        .fan-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            pointer-events: none; /* Prevents img from stealing mouse events */
        }
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .cover-title-display {
            margin-top: 40px;
            color: var(--gold-accent);
            font-family: var(--font-title);
            font-size: 1.5rem;
            text-align: center;
            text-shadow: 0 0 10px rgba(184, 149, 72, 0.5);
            max-width: 80%;
        }

        /* --- Quest Tooltip --- */
        .q-tooltip {
            position: fixed;
            background: #050a0f;
            color: #e0f7fa;
            border: 1px solid var(--gold-accent);
            padding: 12px;
            border-radius: 4px;
            pointer-events: none;
            opacity: 0;
            z-index: 2000;
            box-shadow: 0 10px 30px rgba(0,0,0,0.8);
            max-width: 300px;
            font-family: var(--font-body);
            transition: opacity 0.1s;
        }
        .q-tooltip-title {
            color: var(--gold-accent);
            font-family: var(--font-title);
            font-size: 0.8rem;
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid rgba(184, 149, 72, 0.3);
            padding-bottom: 3px;
            display: block;
        }
        .q-tooltip-trigger {
            font-size: 0.9rem;
            line-height: 1.4;
            display: block;
        }
    </style>

    <script>
        let currentQuests = [];

        async function openQuestBoard(e) {
            if (e) e.preventDefault();
            const modal = document.getElementById('quest-modal');
            const list = document.getElementById('quest-list');
            
            modal.style.display = 'flex';
            list.innerHTML = '<div style="color:var(--gold-accent); font-family:var(--font-title);">SCANNING DATABASE...</div>';

            try {
                const res = await fetch('/awards/api/gear/quests');
                currentQuests = await res.json();
                
                // Sort alphabetically by achievement name
                currentQuests.sort((a, b) => {
                    const nameA = (a.achievement || a.quest_name || "").toUpperCase();
                    const nameB = (b.achievement || b.quest_name || "").toUpperCase();
                    if (nameA < nameB) return -1;
                    if (nameA > nameB) return 1;
                    return 0;
                });

                list.innerHTML = "";
                currentQuests.forEach(q => {
                    const post = document.createElement('div');
                    post.className = 'quest-post';
                    
                    // Logic for Rarity Colors
                    const rarity = (q.rarity || 'common').toLowerCase();
                    post.style.borderLeftColor = `var(--r-${rarity})`;
                    
                    // Logic for Directive Labels
                    const typeLabel = q.directive_type || 'Directive';
                    const xpVal = q.display_xp || 0;
                    
                    // Unique ID check
                    const id = q.id || q.quest_id;
                    post.onclick = () => showQuestCovers(id);

                    // Tooltip Events
                    post.onmouseenter = (e) => showQuestTooltip(q.trigger, e);
                    post.onmousemove = (e) => moveQuestTooltip(e);
                    post.onmouseleave = () => hideQuestTooltip();
                    
                    const rewardLabel = q.rarity === 'Legendary' ? 'Artifact Manifest' : 'System Bounty';

                    post.innerHTML = `
                        <span class="q-type">${typeLabel}</span>
                        <span class="q-name">${q.achievement || q.quest_name}</span>
                        <span class="q-target">${q.title}</span>
                        <p class="q-desc">"${q.flavorText || q.description}"</p>
                        <div class="q-rewards">
                            <span class="q-xp" style="color: ${xpVal >= 500000 ? '#ff3c00' : '#00e5ff'}">${xpVal.toLocaleString()} EXP</span>
                            <span class="q-loot">${rewardLabel}</span>
                        </div>
                    `;
                    list.appendChild(post);
                });

            } catch (err) {
                list.innerHTML = '<div style="color:#ff5555">ERROR: ACCESS DENIED</div>';
            }
        }

        function showQuestTooltip(trigger, e) {
            const tip = document.getElementById('quest-tooltip');
            if (!trigger) return;
            
            tip.innerHTML = `
                <span class="q-tooltip-title">Quest Requirement</span>
                <span class="q-tooltip-trigger">${trigger}</span>
            `;
            tip.style.opacity = '1';
            moveQuestTooltip(e);
        }

        function moveQuestTooltip(e) {
            const tip = document.getElementById('quest-tooltip');
            const x = e.clientX + 15;
            const y = e.clientY + 15;
            
            // Boundary checks
            const width = tip.offsetWidth;
            const height = tip.offsetHeight;
            const finalX = (x + width > window.innerWidth) ? e.clientX - width - 15 : x;
            const finalY = (y + height > window.innerHeight) ? e.clientY - height - 15 : y;

            tip.style.left = finalX + 'px';
            tip.style.top = finalY + 'px';
        }

        function hideQuestTooltip() {
            document.getElementById('quest-tooltip').style.opacity = '0';
        }

        function showQuestCovers(questId) {
            const q = currentQuests.find(x => (x.id === questId || x.quest_id === questId));
            if (!q || !q.books || q.books.length === 0) return;

            const overlay = document.getElementById('cover-overlay');
            const fan = document.getElementById('cover-fan');
            const title = document.getElementById('cover-title');

            fan.innerHTML = "";
            title.textContent = q.title || q.target_name;
            overlay.style.display = 'flex';

            q.books.forEach((book, idx) => {
                const div = document.createElement('div');
                div.className = 'fan-item';
                div.title = book.title;
                div.innerHTML = `<img src="/awards/covers/${encodeURIComponent(book.cover)}">`;
                
                // Calculate Fan spread
                const count = q.books.length;
                const center = (count - 1) / 2;
                const offset = idx - center;
                
                // Delayed entry animation
                setTimeout(() => {
                    div.style.transform = `translateX(${offset * 80}px) rotate(${offset * 8}deg) scale(${1 - Math.abs(offset) * 0.05})`;
                    div.style.zIndex = count - Math.abs(offset);
                }, 100);

                fan.appendChild(div);
            });
        }

        function closeCovers() {
            document.getElementById('cover-overlay').style.display = 'none';
        }

        function closeQuestBoard() {
            document.getElementById('quest-modal').style.display = 'none';
        }

        // Close on escape key
        window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeCovers();
                closeQuestBoard();
            }
        });
    </script>

    <div style="position: fixed; bottom: 10px; right: 10px; z-index: 100;">
        <a href="/system-alert" style="color: rgba(255, 42, 42, 0.4); font-size: 0.7rem; text-decoration: none; font-family: var(--font-title); letter-spacing: 1px; transition: color 0.3s;" onmouseover="this.style.color='rgba(255, 42, 42, 1)'" onmouseout="this.style.color='rgba(255, 42, 42, 0.4)'">
            [ RE-VIEW SYSTEM DIRECTIVE ]
        </a>
    </div>

</body>
</html>