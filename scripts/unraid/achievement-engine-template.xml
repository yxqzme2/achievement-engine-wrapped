  <PostArgs/>
  <CPUset/>
  <DateInstalled>1773918217</DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="data" Target="/data" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/achievement-engine/</Config>
  <Config Name="covers" Target="/data/covers" Default="" Mode="rw" Description="Optional: path to abs-stats covers folder for local serving. If not mapped, cover images proxy through abs-stats API." Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/achievement-engine/covers</Config>
  <Config Name="ABSSTATS_BASE_URL" Target="ABSSTATS_BASE_URL" Default="" Mode="" Description="" Type="Variable" Display="always" Required="false" Mask="false">http://abs-stats:3000</Config>
  <Config Name="POLL_SECONDS" Target="POLL_SECONDS" Default="" Mode="" Description="" Type="Variable" Display="always" Required="false" Mask="false">300</Config>
  <Config Name="STATE_DB_PATH" Target="STATE_DB_PATH" Default="" Mode="" Description="" Type="Variable" Display="always" Required="false" Mask="false">/data/state.db</Config>
  <Config Name="TZ" Target="TZ" Default="" Mode="" Description="" Type="Variable" Display="always" Required="false" Mask="false">America/New_York</Config>
  <Config Name="XP_START_TIMESTAMP" Target="XP_START_TIMESTAMP" Default="" Mode="" Description="Unix timestamp (seconds) when progression economy starts. XP/loot/levels use this boundary." Type="Variable" Display="always" Required="false" Mask="false">1767157260</Config>
  <Config Name="VERIFY_LISTEN_THRESHOLD" Target="VERIFY_LISTEN_THRESHOLD" Default="" Mode="" Description="Completion verification ratio (timeListening / duration). Used only when STRICT_VERIFICATION=true." Type="Variable" Display="always" Required="false" Mask="false">0.80</Config>
  <Config Name="STRICT_VERIFICATION" Target="STRICT_VERIFICATION" Default="" Mode="" Description="If true, progression requires verification rules. If false, progression uses completion timestamps only." Type="Variable" Display="always" Required="false" Mask="false">false</Config>
  <Config Name="REQUIRE_DURATION_FOR_CREDIT" Target="REQUIRE_DURATION_FOR_CREDIT" Default="" Mode="" Description="If true, books with unknown duration are excluded from progression credit." Type="Variable" Display="always" Required="false" Mask="false">true</Config>
  <Config Name="REQUIRE_2026_SESSION_FOR_CREDIT" Target="REQUIRE_2026_SESSION_FOR_CREDIT" Default="" Mode="" Description="If true, requires at least one session at/after XP_START_TIMESTAMP for progression credit (when STRICT_VERIFICATION=true)." Type="Variable" Display="always" Required="false" Mask="false">true</Config>
  <Config Name="WRAPPED_BOSS_HP" Target="WRAPPED_BOSS_HP" Default="" Mode="" Description="Boss HP used by wrapped combat and picker state." Type="Variable" Display="always" Required="false" Mask="false">250000</Config>
  <Config Name="WRAPPED_ENABLED" Target="WRAPPED_ENABLED" Default="" Mode="" Description="Enable or disable Wrapped pages and links." Type="Variable" Display="always" Required="false" Mask="false">false</Config>
  <Config Name="WRAPPED_YEAR" Target="WRAPPED_YEAR" Default="" Mode="" Description="Admin-only override for Wrapped report year (e.g., 2026, 2027)." Type="Variable" Display="always" Required="false" Mask="false">2026</Config>
  <Config Name="RADAR_CHECK_INTERVAL_HOURS" Target="RADAR_CHECK_INTERVAL_HOURS" Default="12" Mode="" Description="How often Release Radar polls Audible for new releases in tracked series (hours). Default: 12" Type="Variable" Display="always" Required="false" Mask="false">12</Config>
  <Config Name="ADMIN_EMAIL" Target="ADMIN_EMAIL" Default="" Mode="" Description="Email address for user Series Request submissions via /request page." Type="Variable" Display="always" Required="false" Mask="false">mrlarue77@gmail.com</Config>
